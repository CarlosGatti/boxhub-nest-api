<html>
<head>
  <meta charset="UTF-8" />
<style>
      .wrapper {
        width: 100%;
        background: #f7fafc;
        padding: 32px 0;
        font-family: Arial, sans-serif;
      }
      .content {
        max-width: 480px;
        margin: auto;
        background: #ffffff;
        padding: 32px;
        border-radius: 8px;
        text-align: center;
    }
    .logo {
      margin-bottom: 24px;
    }
    .logo img {
        max-width: 180px;
        height: auto;
    }
    .title {
        font-size: 24px;
        font-weight: bold;
      color: #2d3748;
      margin-bottom: 16px;
    }
      .subtitle {
        font-size: 16px;
      color: #4a5568;
        margin-bottom: 24px;
      line-height: 1.6;
    }
      .cta-button {
      display: inline-block;
        padding: 12px 24px;
        background: #3182ce;
      color: white;
        border-radius: 6px;
      text-decoration: none;
        font-weight: bold;
        margin-bottom: 24px;
    }
    .footer {
        margin-top: 32px;
        font-size: 12px;
        color: #4a5568;
      text-align: center;
    }
  </style>
</head>
<body>
    <div class="wrapper">
      <div class="content">
<div class="logo">
  <img
            src="{{logoUrl}}"
            alt="carlosgatti.com"
  />
</div>
    <div class="title">{{title}}</div>
        <div class="subtitle">
      A password reset has been requested for your account.<br />
      If this was you, please click the button below to set a new password.
    </div>
        <a class="cta-button" href="{{resetUrl}}" target="_blank">
        Reset Password
      </a>
        <div class="subtitle" style="margin-top: 24px; font-size: 14px;">
      If you did not request this, you can safely ignore this email.<br />
      Your password will remain unchanged.
    </div>
        <p class="footer">
          © {{year}} Defined — Powered by carlosgatti.com
        </p>
    </div>
  </div>
</body>
</html>

<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      .wrapper {
        width: 100%;
        background: #f7fafc;
        padding: 32px 0;
        font-family: Arial, sans-serif;
      }
      .content {
        max-width: 560px;
        margin: auto;
        background: #ffffff;
        padding: 32px;
        border-radius: 8px;
        text-align: left;
      }
      .title {
        font-size: 22px;
        font-weight: bold;
        color: #2d3748;
        margin-bottom: 20px;
      }
      .info-row {
        margin-bottom: 10px;
        font-size: 14px;
      }
      .info-label {
        font-weight: bold;
        color: #2d3748;
      }
      .info-value {
        color: #4a5568;
      }
      .message-box {
        background: #f7fafc;
        border-left: 4px solid #3182ce;
        padding: 16px;
        margin: 16px 0;
        border-radius: 4px;
        white-space: pre-wrap;
      }
      .footer {
        margin-top: 28px;
        font-size: 12px;
        color: #718096;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="content">
        <div class="title">New Defined lead (landing page)</div>
        <div class="info-row"><span class="info-label">Lead ID:</span> <span class="info-value">{{leadId}}</span></div>
        <div class="info-row"><span class="info-label">Submitted:</span> <span class="info-value">{{createdAt}}</span></div>
        <div class="info-row"><span class="info-label">Name:</span> <span class="info-value">{{fullName}}</span></div>
        <div class="info-row"><span class="info-label">Email:</span> <span class="info-value">{{email}}</span></div>
        <div class="info-row"><span class="info-label">Phone:</span> <span class="info-value">{{phone}}</span></div>
        <div class="info-row"><span class="info-label">Company:</span> <span class="info-value">{{companyName}}</span></div>
        <div class="info-row"><span class="info-label">Package:</span> <span class="info-value">{{selectedPackage}}</span></div>
        <div class="info-row"><span class="info-label">Service interest:</span> <span class="info-value">{{serviceInterest}}</span></div>
        <div class="info-row"><span class="info-label">Landing slug:</span> <span class="info-value">{{landingSlug}}</span></div>
        <div class="info-row"><span class="info-label">UTM:</span> <span class="info-value">{{utmSummary}}</span></div>
        <div class="info-row"><span class="info-label">gclid / fbclid:</span> <span class="info-value">{{clickIds}}</span></div>
        {{#if message}}
        <div class="info-row"><span class="info-label">Message:</span></div>
        <div class="message-box">{{message}}</div>
        {{/if}}
        <p class="footer">Defined lead capture — internal notification only.<br />© {{year}} Defined</p>
      </div>
    </div>
  </body>
</html>
